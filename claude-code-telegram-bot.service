[Unit]
Description=Claude Code Telegram Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/telegram-claude-bot
EnvironmentFile=/root/telegram-claude-bot/.env
ExecStart=/usr/bin/python3 /root/telegram-claude-bot/bot.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
